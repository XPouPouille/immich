# Immich domain
IMMICH_DOMAIN=photos.example.com

# Immich version (leave as release for latest stable)
IMMICH_VERSION=release

# Upload location on host
UPLOAD_LOCATION=/opt/immich/photos

# Database
DB_PASSWORD=changeme_strong_password
DB_USERNAME=immich
DB_DATABASE_NAME=immich

# Redis
REDIS_HOSTNAME=redis
